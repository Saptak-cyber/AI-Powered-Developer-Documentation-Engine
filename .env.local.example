# AI-Powered Developer Documentation Engine — Environment Variables
# Copy this file to .env.local and fill in your values.
# .env.local is gitignored — never commit secrets.

# ─── LLM Provider (any OpenAI-compatible endpoint) ───────────────────────────
# Swap provider by only changing these three vars — no code changes needed.
#
# OpenAI:     LLM_BASE_URL=https://api.openai.com/v1
# Gemini:     LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
# Together:   LLM_BASE_URL=https://api.together.xyz/v1
# Groq:       LLM_BASE_URL=https://api.groq.com/openai/v1
# Ollama:     LLM_BASE_URL=http://localhost:11434/v1

LLM_API_KEY=your_llm_api_key_here
LLM_BASE_URL=https://integrate.api.nvidia.com/v1
LLM_MODEL=nvidia/nemotron-3-super-120b-a12b

# ─── Embedding Model (HuggingFace Inference API) ─────────────────────────────
# Embeddings are generated via the HuggingFace Inference API, not the LLM provider.
# Get your free API key at: https://huggingface.co/settings/tokens
#
# Recommended models and their output dimensions:
#   BAAI/bge-small-en-v1.5    → 384  dims  (fast, great quality, free tier friendly)
#   BAAI/bge-base-en-v1.5     → 768  dims
#   BAAI/bge-large-en-v1.5    → 1024 dims
#   sentence-transformers/all-MiniLM-L6-v2 → 384 dims
#
# IMPORTANT: EMBEDDING_DIMENSIONS must match the dimension of the chosen model
# AND the Qdrant collection vector size (set once at collection creation).

HF_API_KEY=your_huggingface_api_key_here
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_DIMENSIONS=384

# ─── Neon DB (PostgreSQL) ────────────────────────────────────────────────────
# Get from: https://console.neon.tech → your project → Connection Details
# Use the "pooled" URL for DATABASE_URL and "direct" for DIRECT_URL

DATABASE_URL=postgresql://user:password@ep-xxx-yyy.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require
DIRECT_URL=postgresql://user:password@ep-xxx-yyy.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require

# ─── Qdrant Cloud ────────────────────────────────────────────────────────────
# Get from: https://cloud.qdrant.io → your cluster → API Keys

QDRANT_URL=https://your-cluster-id.eu-west-2-0.aws.cloud.qdrant.io
QDRANT_API_KEY=your_qdrant_api_key_here
QDRANT_COLLECTION=doc_embeddings

# ─── GitHub ──────────────────────────────────────────────────────────────────
# Create at: https://github.com/settings/tokens → Fine-grained token
# Required scopes: repo:read (or "Contents: Read" for fine-grained)

GITHUB_TOKEN=your_github_personal_access_token_here

# ─── Next.js ─────────────────────────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
